# Supabase — create a project at https://supabase.com
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Sentry error tracking (optional)
VITE_SENTRY_DSN=https://your-dsn@sentry.io/project
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ORG=your-org
SENTRY_PROJECT=pandagarde

# Google Analytics (optional)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# SocialCaution funnel (optional overrides)
VITE_SOCIALCAUTION_WEB_URL=https://www.socialcaution.com
VITE_SOCIALCAUTION_APP_URL=https://app.socialcaution.com
