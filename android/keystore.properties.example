# Copy to android/keystore.properties (gitignored) and fill in before release builds.
# Generate keystore (once):
#   keytool -genkey -v -keystore pandagarde-familyhub-upload.jks -keyalg RSA -keysize 2048 -validity 10000 -alias upload

storeFile=pandagarde-familyhub-upload.jks
storePassword=YOUR_STORE_PASSWORD
keyAlias=upload
keyPassword=YOUR_KEY_PASSWORD
