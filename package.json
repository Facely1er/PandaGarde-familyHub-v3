{
  "name": "vite-react-typescript-starter",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0 <21",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:familyhub": "vite build --config vite.familyhub.config.ts",
    "dev:familyhub": "vite --config vite.familyhub.config.ts",
    "preview:familyhub": "vite preview --config vite.familyhub.config.ts --outDir dist-familyhub",
    "cap:sync": "npm run build:familyhub && npx cap sync",
    "cap:sync:android": "npm run build:familyhub && npx cap sync android",
    "cap:sync:ios": "npm run build:familyhub && npx cap sync ios",
    "cap:android": "npm run android:local-props && npm run cap:sync:android && npx cap open android",
    "cap:ios": "npm run cap:sync && npx cap open ios",
    "mobile:prepare": "npm run build:familyhub && npx cap sync",
    "mobile:bump": "node scripts/bump-familyhub-version.mjs",
    "mobile:bump:build": "node scripts/bump-familyhub-version.mjs --build",
    "android:local-props": "node scripts/ensure-android-local-properties.mjs",
    "android:debug": "npm run android:local-props && npm run build:familyhub && npx cap sync android && npm run android:assembleDebug",
    "android:assembleDebug": "node scripts/ensure-android-local-properties.mjs && cd android && gradlew.bat assembleDebug",
    "android:bundleRelease": "node scripts/ensure-android-local-properties.mjs && cd android && gradlew.bat bundleRelease",
    "assets:generate": "capacitor-assets generate --android --ios",
    "assets:generate:all": "capacitor-assets generate",
    "deploy:check": "npm run test:launch-smoke && npm run build:familyhub && node scripts/verify-deploy-assets.mjs",
    "deploy:netlify:familyhub": "netlify deploy --prod --dir=dist-familyhub --site 09a33b67-21f2-4f27-bc38-1b732b9cf29e --no-build",
    "deploy:netlify:all": "npm run deploy:check && npm run deploy:netlify && npm run deploy:netlify:familyhub",
    "check:content-truth": "node scripts/check-content-truth.mjs",
    "check:routes": "node scripts/verify-routes.mjs",
    "check:story-assets": "node scripts/verify-story-scene-assets.mjs",
    "assets:story-covers": "node scripts/crop-story-covers.mjs",
    "assets:story-covers:verify": "node scripts/verify-story-covers.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "vite preview",
    "deploy:netlify": "netlify deploy --prod --dir=dist --site 2e41bc3f-2d27-469f-a104-c8ddcee69883 --no-build",
    "deploy:netlify:journal": "netlify deploy --prod --dir=Digital_Bamboo_Journal/pandagarde-digital-bamboo-journal --site 520d418f-3aaf-4ce0-b0c6-7be6a14ded11 --no-build",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:dfa": "vitest run src/lib/dfaJourney.test.ts src/lib/dfaScoreEngine.test.ts src/components/journey/DfaJourneyStepper.test.tsx src/components/dfa/DfaScoreOverview.test.tsx",
    "test:launch-smoke": "npm run test:dfa && npm run build",
    "test:e2e": "playwright test e2e/core-advertised.spec.ts",
    "test:watch-dfa": "vitest src/lib/dfaJourney.test.ts src/lib/dfaScoreEngine.test.ts src/components/journey/DfaJourneyStepper.test.tsx src/components/dfa/DfaScoreOverview.test.tsx"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.2",
    "@capacitor/browser": "^7.0.5",
    "@capacitor/core": "^7.4.2",
    "@capacitor/ios": "^7.4.2",
    "framer-motion": "^11.0.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-beautiful-dnd": "^13.1.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.8.2"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^7.4.2",
    "@eslint/js": "^9.9.1",
    "@playwright/test": "^1.49.1",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.5",
    "@types/react-beautiful-dnd": "^13.1.8",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^4.0.15",
    "autoprefixer": "^10.4.18",
    "dotenv": "^16.4.5",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "jsdom": "^27.2.0",
    "postcss": "^8.4.35",
    "prettier": "^3.2.5",
    "sharp": "^0.34.5",
    "svgo": "^4.0.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.3.0",
    "vite": "^7.1.5",
    "vitest": "^4.0.10"
  }
}
