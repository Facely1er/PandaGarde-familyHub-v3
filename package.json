{
  "name": "vite-react-typescript-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0 <21",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:familyhub": "vite build --config vite.familyhub.config.ts",
    "dev:familyhub": "vite --config vite.familyhub.config.ts",
    "preview:familyhub": "vite preview --config vite.familyhub.config.ts --outDir dist-familyhub",
    "cap:sync": "npm run build:familyhub && npx cap sync",
    "cap:android": "npm run cap:sync && npx cap open android",
    "cap:ios": "npm run cap:sync && npx cap open ios",
    "assets:generate": "capacitor-assets generate --android",
    "assets:generate:all": "capacitor-assets generate",
    "deploy:netlify:familyhub": "npm run build:familyhub && netlify deploy --prod --dir=dist-familyhub --site 09a33b67-21f2-4f27-bc38-1b732b9cf29e --no-build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "vite preview",
    "deploy:netlify": "netlify deploy --prod",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:dfa": "vitest run src/lib/dfaJourney.test.ts src/lib/dfaScoreEngine.test.ts src/components/journey/DfaJourneyStepper.test.tsx src/components/dfa/DfaScoreOverview.test.tsx",
    "test:launch-smoke": "npm run test:dfa && npm run build",
    "test:watch-dfa": "vitest src/lib/dfaJourney.test.ts src/lib/dfaScoreEngine.test.ts src/components/journey/DfaJourneyStepper.test.tsx src/components/dfa/DfaScoreOverview.test.tsx"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.2",
    "@capacitor/core": "^7.4.2",
    "@capacitor/ios": "^7.4.2",
    "framer-motion": "^11.0.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-beautiful-dnd": "^13.1.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.8.2"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^7.4.2",
    "@eslint/js": "^9.9.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.5",
    "@types/react-beautiful-dnd": "^13.1.8",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^4.0.15",
    "autoprefixer": "^10.4.18",
    "dotenv": "^16.4.5",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "jsdom": "^27.2.0",
    "postcss": "^8.4.35",
    "prettier": "^3.2.5",
    "svgo": "^4.0.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.3.0",
    "vite": "^7.1.5",
    "vitest": "^4.0.10"
  }
}
